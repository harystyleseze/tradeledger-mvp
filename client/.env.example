# ============================================
# TradeLedger Client — Environment Variables
# ============================================
# For LOCAL development: leave VITE_API_URL empty or unset.
#   Vite's dev proxy (vite.config.js) forwards API calls to localhost:3001.
#
# For VERCEL production: set VITE_API_URL to your Render backend URL.
#   Go to Vercel → Project Settings → Environment Variables → add:
#
#   Name:  VITE_API_URL
#   Value: https://YOUR-RENDER-SERVICE-NAME.onrender.com
#
#   Example: https://tradeledger-server.onrender.com
#
# IMPORTANT: No trailing slash! The frontend appends paths like /merchants, /buyers, etc.

VITE_API_URL=
