# ============================================
# TradeLedger Server — Environment Variables
# ============================================
# Copy this to .env for local development.
# On Render: paste these values into the web service's Environment tab.

# --- Nomba API ---
# Sandbox: https://sandbox.nomba.com/v1
# Production: https://api.nomba.com/v1
NOMBA_BASE_URL=https://sandbox.nomba.com/v1
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=
NOMBA_WEBHOOK_SECRET=

# --- Database ---
# Local:  postgresql://user:password@localhost:5432/tradeledger
# Render: Use the "Internal Database URL" from your Render PostgreSQL dashboard
#         Format: postgresql://USER:PASSWORD@HOST/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/tradeledger

# --- CORS ---
# The URL(s) of your frontend. Comma-separated for multiple origins.
# This MUST match your Vercel deployment URL exactly (no trailing slash).
# Example: https://tradeledger-mvp-i5zj-eight.vercel.app
CORS_ORIGIN=

# --- Server ---
PORT=3001
NODE_ENV=development
